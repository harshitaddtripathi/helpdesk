{
  "name": "ai-helpdesk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "bun run db:generate",
    "dev": "bun run scripts/dev.ts",
    "dev:api": "bun --watch server/src/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "bun run db:generate && bun run typecheck && bun run build:client && bun run build:server",
    "build:backend": "bun run db:generate && bun run typecheck:backend && bun run build:server",
    "build:client": "vite build",
    "build:server": "bun build server/src/index.ts --target=bun --outdir dist/server --external @prisma/client",
    "start": "bun run scripts/start.ts",
    "test:component": "vitest run",
    "test:server": "vitest run --config server/vitest.config.ts",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "typecheck:backend": "tsc -p server/tsconfig.json --noEmit && tsc -p scripts/tsconfig.json --noEmit",
    "typecheck": "tsc -p server/tsconfig.json --noEmit && tsc -p client/tsconfig.json --noEmit && tsc -p scripts/tsconfig.json --noEmit",
    "db:generate": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.11",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "7.6.0",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "ai": "^7.0.22",
    "axios": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "lucide-react": "^1.23.0",
    "pg-boss": "^12.26.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.81.0",
    "react-router": "^8.1.0",
    "react-router-dom": "^7.0.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "^1.2.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "prisma": "7.6.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.10"
  }
}
