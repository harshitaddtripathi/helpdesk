{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "bun install --frozen-lockfile --ignore-scripts",
  "buildCommand": "bun run build:client",
  "outputDirectory": "dist/client",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "${API_BASE_URL}/api/$1",
      "env": ["API_BASE_URL"]
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
